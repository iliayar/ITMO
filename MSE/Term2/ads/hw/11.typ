#solution[
  1. $chevron.l #text[несовместна], #text[несовместна] chevron.r$
    $ cases(
        1 dot x_1 + 0 dot x_2 <= -1,
        0 dot x_1 + 1 dot x_2 -> max,
        x_1"," x_2 >= 0,
      ) quad
      cases(
      1 dot y_1 >= 0,
      0 dot y_1 >= 1,
      -1 dot y_1 -> min,
      ) $
  2. $chevron.l #text[несовместна], #text[неограничена] chevron.r$
    $ cases(
        1 dot x_1 <= -1,
        1 dot x_1 -> max,
        x_1 >= 0,
      ) quad
      cases(
        1 dot y_1 >= 1,
        -1 dot y_1 -> min,
        y_1 >= 0,
      ) $
  3. $chevron.l #text[неограничена], #text[несовместна] chevron.r$
    $ cases(
        -1 dot x_1 <= -1,
        1 dot x_1 -> max,
        x_1 >= 0,
      ) quad
      cases(
        -1 dot y_1 >= 1,
        -1 dot y_1 -> min,
        y_1 >= 0,
      ) $
  4. $chevron.l #text[несовместна], #text[имеет конечное решение] chevron.r$. По слабой двойственности
    $ "OPT"(P) <= "OPT"(P^*) = C $
    должно существовать $"OPT"(P) <= C$ а значит $P$ должно иметь конечное решение
  5. $chevron.l #text[неограничена], #text[имеет конечное решение] chevron.r$. Аналогично
  6. $chevron.l #text[имеет конечное решение], #text[несовместна] chevron.r$. По слабой двойственности
    $ C = "OPT"(P) <= "OPT"(P^*) $
    должно существовать $"OPT"(P^*) >= C$ а занчит $P^*$ должно иметь конечное решение
  7. $chevron.l #text[имеет конечное решение], #text[неограничена] chevron.r$. Аналогично
  8. $chevron.l #text[неограничена], #text[неограничена] chevron.r$. По слабой двойственности
    $ + infinity = "OPT"(P) <= "OPT"(P^*) = - infinity $
    противоречие
  9. $chevron.l #text[имеет конечное решение], #text[имеет конечное решение] chevron.r$
    $ cases(
        1 dot x_1 <= 1,
        1 dot x_1 -> max,
        x_1 >= 0,
      ) ==> x_1 = 1 quad
      cases(
        1 dot y_1 >= 1,
        1 dot y_1 -> min,
        y_1 >= 0,
      ) ==> y_1 = 1 $
]

