#task(numbering: (..) => numbering("1.a", 1, 1))[]
#solution[
  $ Pr [h(x_1) = y_1 and h(x_2) = y_2] = 1 / (|Y|^k) $
  Тогда
  $ Pr [h(x_1) = h(x_2)] = Pr [or.big_(y in Y) h(x_1) = y and h(x_2) = y] = \
    = sum_(y in Y) Pr [h(x_1) = y and h(x_2) = y] = sum_(y in Y) 1 / (|Y|^2) = |Y| dot 1 / (|Y|^2) = 1 / (|Y|) <= 1 / (|Y|)
  $
]

#task(numbering: (..) => numbering("1.a", 1, 2))[]
#solution[
  Заметим что
  $ union.big_(y in Y) [h(x_(k + 1)) = y and (and.big_(i = 1)^k h(x_i) = y_i)] = [and.big_(i = 1)^k h(x_i) = y_i] $
  где $x_(k + 1) != x_i$. Тогда по $(k + 1)$-независимости для любого $y$
  $ Pr [h(x_(k + 1)) = y and (and.big_(i = 1)^k h(x_i) = y_i)] = 1/(|Y|^(k + 1)) $
  Тогда
  $ Pr union.big_(y in Y) [h(x_(k + 1)) = y and (and.big_(i = 1)^k h(x_i) = y_i)] = sum_(y in Y) Pr [h(x_(k + 1)) = y and (and.big_(i = 1)^k h(x_i) = y_i)] = \
    = sum_(y in Y) 1 / (|Y|^(k + 1)) = |Y| dot 1 / (|Y|^(k + 1)) = 1 / (|Y|^k) = Pr [and.big_(i = 1)^k h(x_i) = y_i]
  $
  Значит $cal(H)$ $k$-независимо.
]

